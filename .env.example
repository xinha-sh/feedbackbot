# ── Required for deploy ──────────────────────────────────────────
# Generate all three with:
#   openssl rand -base64 32

BETTER_AUTH_SECRET=
# base64-encoded 32 bytes — AES-GCM master key for per-workspace
# HKDF-derived credential encryption. Rotating this invalidates all
# stored integration credentials.
INTEGRATIONS_ENCRYPTION_KEY=
# Used by HMAC-SHA256 for: outbound webhook signatures, screenshot
# upload/get tokens, vote fingerprints, daily ip_hash salt.
HMAC_SECRET_SEED=

# Canonical origin of the deployed app. Better Auth + signed
# screenshot URLs read this. Set to your apex/subdomain.
BETTER_AUTH_URL=https://usefeedbackbot.com

# ── Required for GitHub sign-in ──────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional ─────────────────────────────────────────────────────
# Slack OAuth for the Slack integration (admin UI deferred)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Sentry DSN — leave empty to skip error tracking in production
SENTRY_DSN=

# Dodo Payments — leave empty to disable billing.
# Create a bearer token at https://app.dodopayments.com/developer/api-keys
# The webhook secret is the "signing secret" of the endpoint you create
# pointing at <BETTER_AUTH_URL>/api/auth/dodopayments/webhooks.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
# test_mode | live_mode — default test_mode if unset
DODO_PAYMENTS_ENV=test_mode

# Unosend — transactional email (magic links). Signup at unosend.co,
# verify usefeedbackbot.com, paste the API key below. When unset the
# app falls back to Cloudflare EmailSender (which only sends to
# verified destination addresses — fine for testing, not signups).
UNOSEND_API_KEY=
UNOSEND_FROM="FeedbackBot <noreply@usefeedbackbot.com>"

# Cloudflare Turnstile — gates /api/ticket against bot spam.
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# (Mode: "Managed" = invisible-by-default with fallback challenges).
# Hostname field: add ANY placeholder (e.g. usefeedbackbot.com) to
# satisfy the form — we PATCH new customer domains in via the API
# below on every successful DNS verification.
# Leave TURNSTILE_SECRET empty to disable the gate (graceful bypass).
TURNSTILE_SECRET=

# Cloudflare API token for Turnstile-widget admin (PATCH the
# allowlist when a customer verifies their domain). Create at:
# https://dash.cloudflare.com/profile/api-tokens
# Permissions: Account > Turnstile > Edit (nothing else).
# Account resources: limit to the account that owns the widget.
CF_API_TOKEN=
CF_ACCOUNT_ID=
# The Turnstile widget's public site key. Read by the server at
# runtime (for admin PATCH) AND baked into public/widget.js at
# build time — `pnpm build:widget` reads this same env var.
# Single source of truth on purpose; see vite.widget.config.ts.
CF_TURNSTILE_WIDGET_ID=

# ── Client-side (exposed in bundle) ──────────────────────────────
VITE_POSTHOG_KEY=
