{
  "name": "feedbackbot",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "bun run build && wrangler deploy",
    "deploy:preview": "alchemy deploy --stage \"${STAGE:?STAGE env var required}\"",
    "destroy:preview": "alchemy destroy --stage \"${STAGE:?STAGE env var required}\" --yes",
    "deploy:prod": "alchemy deploy --stage production",
    "build:widget": "vite build --config vite.widget.config.ts"
  },
  "dependencies": {
    "@better-auth/sso": "^1.6.6",
    "@dodopayments/better-auth": "^1.6.2",
    "@posthog/react": "^1.7.0",
